<?xml version="1.0" encoding="utf-8" ?>
<local:BaseContentPage  
    xmlns:local="clr-namespace:MyRoutineNew"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MyRoutineNew.Routine"
    BackgroundColor="#FDF7F0">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── HEADER ── -->
        <VerticalStackLayout Grid.Row="0" Padding="20,48,20,16" Spacing="4">
            <Label Text="Agenda" FontSize="22" FontAttributes="Bold" TextColor="#1C1409"/>
            <Label x:Name="LabelMeseCorrente" Text="" FontSize="12" TextColor="#7A6850"/>
        </VerticalStackLayout>

        <!-- ── LISTA GIORNI + TASK (dinamica) ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="StackGiorni" Spacing="0" Padding="0,0,0,20"/>
        </ScrollView>

        <!-- ── FAB: Aggiungi task ── -->
        <Button
            Grid.Row="2"
            x:Name="BtnAggiungi"
            Text="+ Aggiungi Task"
            Clicked="OnAggiungiClicked"
            Margin="20,8,20,16"
            BackgroundColor="#F97316"
            TextColor="White"
            FontSize="15" FontAttributes="Bold"
            HeightRequest="52"
            CornerRadius="16"/>

    </Grid>

</local:BaseContentPage>
