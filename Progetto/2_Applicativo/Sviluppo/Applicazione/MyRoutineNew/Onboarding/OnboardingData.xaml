<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    x:Class="MyRoutineNew.Onboarding.OnboardingData"
    BackgroundColor="#FDF7F0"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto" Padding="32,60,32,40">

        <VerticalStackLayout Grid.Row="0" VerticalOptions="Center" Spacing="32">

            <!-- Step indicator -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                <BoxView WidthRequest="24" HeightRequest="6" BackgroundColor="#F97316" CornerRadius="3"/>
                <BoxView WidthRequest="24" HeightRequest="6" BackgroundColor="#F97316" CornerRadius="3"/>
                <BoxView WidthRequest="24" HeightRequest="6" BackgroundColor="#F97316" CornerRadius="3"/>
                <BoxView WidthRequest="24" HeightRequest="6" BackgroundColor="#EDE5D8" CornerRadius="3"/>
            </HorizontalStackLayout>

            <!-- Icona -->
            <Border
                WidthRequest="80" HeightRequest="80"
                BackgroundColor="#F97316"
                StrokeThickness="0"
                HorizontalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="28"/></Border.StrokeShape>
                <Label Text="🎂" FontSize="36"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <!-- Testi -->
            <VerticalStackLayout Spacing="10">
                <Label Text="Quando sei nato/a?"
                       FontSize="26" FontAttributes="Bold"
                       TextColor="#1C1409"
                       HorizontalTextAlignment="Center"/>
                <Label Text="Ti aiuta a personalizzare la tua esperienza."
                       FontSize="14" TextColor="#7A6850"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap"/>
            </VerticalStackLayout>

            <!-- DatePicker -->
            <VerticalStackLayout Spacing="8"><!--è un po' scomodo trovare anno esatto se non vicino al 2008, es 1992, quindi dovremo rivedere-->
                <Label Text="DATA DI NASCITA"
                       FontSize="11" FontAttributes="Bold"
                       CharacterSpacing="1.5"
                       TextColor="#7A6850"/>
                <Border
                    BackgroundColor="White"
                    Stroke="#E8E0D4"
                    StrokeThickness="1.5"
                    Padding="16,0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                    <DatePicker
                        x:Name="PickerData"
                        Format="dd MMMM yyyy"
                        MaximumDate="{x:Static sys:DateTime.Today}"
                        TextColor="#1C1409"
                        HeightRequest="52"
                        BackgroundColor="Transparent"
                        />
                </Border>
            </VerticalStackLayout>

        </VerticalStackLayout>

        <Button
            Grid.Row="1"
            Text="Avanti →"
            Clicked="OnAvantiClicked"
            BackgroundColor="#F97316"
            TextColor="White"
            FontSize="16" FontAttributes="Bold"
            HeightRequest="54"
            CornerRadius="16"/>

    </Grid>

</ContentPage>
