<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MyRoutineNew.Onboarding.OnboardingFine"
    BackgroundColor="#FDF7F0"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto" Padding="32,60,32,40">

        <VerticalStackLayout Grid.Row="0" VerticalOptions="Center" Spacing="32">

            <!-- Step indicator completo -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                <BoxView WidthRequest="24" HeightRequest="6" BackgroundColor="#F97316" CornerRadius="3"/>
                <BoxView WidthRequest="24" HeightRequest="6" BackgroundColor="#F97316" CornerRadius="3"/>
                <BoxView WidthRequest="24" HeightRequest="6" BackgroundColor="#F97316" CornerRadius="3"/>
                <BoxView WidthRequest="24" HeightRequest="6" BackgroundColor="#F97316" CornerRadius="3"/>
            </HorizontalStackLayout>

            <!-- Icona grande -->
            <Border
                WidthRequest="100" HeightRequest="100"
                BackgroundColor="#F97316"
                StrokeThickness="0"
                HorizontalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="34"/></Border.StrokeShape>
                <Label Text="🚀" FontSize="46"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <!-- Riepilogo -->
            <VerticalStackLayout Spacing="12">
                <Label Text="Tutto pronto!"
                       FontSize="32" FontAttributes="Bold"
                       TextColor="#1C1409"
                       HorizontalTextAlignment="Center"/>
                <Label x:Name="LabelRiepilogo"
                       Text=""
                       FontSize="15" TextColor="#7A6850"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap"/>
            </VerticalStackLayout>

            <!-- Card riepilogo dati -->
            <Border
                BackgroundColor="White"
                Stroke="#E8E0D4"
                StrokeThickness="1"
                Padding="20,16">
                <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="👤" FontSize="16" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="NOME" FontSize="9" TextColor="#B8A88A" FontAttributes="Bold" CharacterSpacing="1"/>
                            <Label x:Name="LabelNomeCard" Text="" FontSize="15" FontAttributes="Bold" TextColor="#1C1409"/>
                        </VerticalStackLayout>
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="#E8E0D4"/>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="🎂" FontSize="16" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="DATA DI NASCITA" FontSize="9" TextColor="#B8A88A" FontAttributes="Bold" CharacterSpacing="1"/>
                            <Label x:Name="LabelDataCard" Text="" FontSize="15" FontAttributes="Bold" TextColor="#1C1409"/>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>

        <!-- Pulsante inizia -->
        <Button
            Grid.Row="1"
            Text="Inizia la tua routine! 🎯"
            Clicked="OnIniziaClicked"
            BackgroundColor="#F97316"
            TextColor="White"
            FontSize="16" FontAttributes="Bold"
            HeightRequest="54"
            CornerRadius="16"/>

    </Grid>

</ContentPage>
